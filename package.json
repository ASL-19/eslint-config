{
  "name": "@asl-19/eslint-config",
  "version": "0.9.0",
  "description": "Shared ESLint config for ASL19 projects",
  "author": {
    "name": "Grant Heaslip",
    "email": "grant@asl19.org",
    "url": "https://asl19.org/"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASL-19/eslint-config.git"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    "types": "./types/index.d.ts",
    "default": "./index.js"
  },
  "files": [
    "configs/**/*.js",
    "types/**/*.d.ts",
    "index.js"
  ],
  "scripts": {
    "eslint-check": "eslint . --ext='js,ts,tsx'",
    "eslint-fix": "eslint . --ext='js,ts,tsx' --fix",
    "lint": "run-p -l eslint-check prettier-check tsc-check",
    "prepack": "run-s tsc",
    "prettier-check": "prettier --check .",
    "prettier-write": "prettier --write .",
    "npm-check-updates": "npm-check-updates",
    "tsc": "tsc",
    "tsc-check": "tsc --noEmit"
  },
  "dependencies": {
    "@arthurgeron/eslint-plugin-react-usememo": "^3.0.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.22.0",
    "@next/eslint-plugin-next": "^15.2.2",
    "@rushstack/eslint-patch": "^1.12.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^16.3.0",
    "typescript-eslint": "^8.39.1"
  },
  "devDependencies": {
    "@types/eslint-plugin-security": "^3.0.0",
    "@types/node": "^24.2.1",
    "eslint": "^9.33.0",
    "npm-check-updates": "^18.0.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "eslint": "^9.33.0"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "rollup": "^4.59.0"
  }
}
