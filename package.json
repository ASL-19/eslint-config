{
  "name": "@asl-19/eslint-config",
  "version": "0.11.0",
  "description": "Shared ESLint config for ASL19 projects",
  "author": {
    "name": "Grant Heaslip",
    "email": "grant@asl19.org",
    "url": "https://asl19.org/"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASL-19/eslint-config.git"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    "types": "./types/index.d.ts",
    "default": "./index.js"
  },
  "files": [
    "configs/**/*.js",
    "types/**/*.d.ts",
    "index.js"
  ],
  "scripts": {
    "eslint-check": "eslint . --ext='js,ts,tsx'",
    "eslint-fix": "eslint . --ext='js,ts,tsx' --fix",
    "lint": "run-p -l eslint-check prettier-check tsc-check",
    "prepack": "run-s tsc",
    "prettier-check": "prettier --check .",
    "prettier-write": "prettier --write .",
    "npm-check-updates": "npm-check-updates",
    "tsc": "tsc",
    "tsc-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.1"
  },
  "devDependencies": {
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "npm-check-updates": "^19.6.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "eslint": "^9.39.4"
  }
}
